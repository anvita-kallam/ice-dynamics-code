{
  "suite_id": "eta_bias_v1",
  "base_cfg": "run_torch_vi_only_optimized.cfg",
  "correlation_gate": 0.82,
  "experiments": [
    {
      "id": "control_adamw",
      "description": "Fresh repeat of the current optimized recipe.",
      "config": "configs/vi_only_eta_bias_suite/control_adamw.cfg",
      "overrides": {},
      "checkdir": "checkpoints/torch_vi_only/eta_bias_suite/eta_bias_v1/control_adamw",
      "logfile": "logs/log_vi_only_eta_bias_eta_bias_v1_control_adamw",
      "evaldir": "outputs/vi_only_eta_bias_suite/eta_bias_v1/control_adamw",
      "summary": "outputs/vi_only_eta_bias_suite/eta_bias_v1/control_adamw/posterior_summary.json"
    },
    {
      "id": "weak_prior",
      "description": "Weaker and broader eta anchor plus mildly weaker inducing KL.",
      "config": "configs/vi_only_eta_bias_suite/weak_prior.cfg",
      "overrides": {
        "train.eta_prior_scale": 0.03,
        "train.eta_prior_std": 2.5,
        "prior.kl_eta": 0.1
      },
      "checkdir": "checkpoints/torch_vi_only/eta_bias_suite/eta_bias_v1/weak_prior",
      "logfile": "logs/log_vi_only_eta_bias_eta_bias_v1_weak_prior",
      "evaldir": "outputs/vi_only_eta_bias_suite/eta_bias_v1/weak_prior",
      "summary": "outputs/vi_only_eta_bias_suite/eta_bias_v1/weak_prior/posterior_summary.json"
    },
    {
      "id": "raised_prior_center",
      "description": "Move the eta anchor center from 12 to 15 MPa yr without weakening it.",
      "config": "configs/vi_only_eta_bias_suite/raised_prior_center.cfg",
      "overrides": {
        "prior.eta_init": 15.0
      },
      "checkdir": "checkpoints/torch_vi_only/eta_bias_suite/eta_bias_v1/raised_prior_center",
      "logfile": "logs/log_vi_only_eta_bias_eta_bias_v1_raised_prior_center",
      "evaldir": "outputs/vi_only_eta_bias_suite/eta_bias_v1/raised_prior_center",
      "summary": "outputs/vi_only_eta_bias_suite/eta_bias_v1/raised_prior_center/posterior_summary.json"
    },
    {
      "id": "strong_physics",
      "description": "Increase SSA weight and tighten residual scales while retaining the incumbent prior.",
      "config": "configs/vi_only_eta_bias_suite/strong_physics.cfg",
      "overrides": {
        "train.phys_scale": 6.0,
        "likelihood.ssa_rx_std": 0.05,
        "likelihood.ssa_ry_std": 0.05,
        "likelihood.ssa_rh_std": 0.05
      },
      "checkdir": "checkpoints/torch_vi_only/eta_bias_suite/eta_bias_v1/strong_physics",
      "logfile": "logs/log_vi_only_eta_bias_eta_bias_v1_strong_physics",
      "evaldir": "outputs/vi_only_eta_bias_suite/eta_bias_v1/strong_physics",
      "summary": "outputs/vi_only_eta_bias_suite/eta_bias_v1/strong_physics/posterior_summary.json"
    },
    {
      "id": "gp_capacity",
      "description": "32x32 inducing points, Matern-5/2, and learnable anisotropic length scales.",
      "config": "configs/vi_only_eta_bias_suite/gp_capacity.cfg",
      "overrides": {
        "prior.num_inducing_x": 32,
        "prior.num_inducing_y": 32,
        "prior.kernel_type": "matern52",
        "prior.anisotropic": true,
        "prior.l_scale_eta_y": 7500.0,
        "train.n_epochs": 200,
        "train.early_stop_patience": 12
      },
      "checkdir": "checkpoints/torch_vi_only/eta_bias_suite/eta_bias_v1/gp_capacity",
      "logfile": "logs/log_vi_only_eta_bias_eta_bias_v1_gp_capacity",
      "evaldir": "outputs/vi_only_eta_bias_suite/eta_bias_v1/gp_capacity",
      "summary": "outputs/vi_only_eta_bias_suite/eta_bias_v1/gp_capacity/posterior_summary.json"
    },
    {
      "id": "optimizer_ngd",
      "description": "AdamW for covariance/kernel parameters plus natural gradients for variational means.",
      "config": "configs/vi_only_eta_bias_suite/optimizer_ngd.cfg",
      "overrides": {
        "train.vgp_optimizer": "adamw_ngd",
        "train.vgp_ngd_lr": 0.003
      },
      "checkdir": "checkpoints/torch_vi_only/eta_bias_suite/eta_bias_v1/optimizer_ngd",
      "logfile": "logs/log_vi_only_eta_bias_eta_bias_v1_optimizer_ngd",
      "evaldir": "outputs/vi_only_eta_bias_suite/eta_bias_v1/optimizer_ngd",
      "summary": "outputs/vi_only_eta_bias_suite/eta_bias_v1/optimizer_ngd/posterior_summary.json"
    },
    {
      "id": "optimizer_fast_cosine",
      "description": "More aggressive AdamW learning rate with a shorter cosine schedule.",
      "config": "configs/vi_only_eta_bias_suite/optimizer_fast_cosine.cfg",
      "overrides": {
        "train.vgp_eta_lr": 0.0005,
        "train.eta_shift_lr": 0.0005,
        "train.lr_scheduler_t_max": 160,
        "train.n_epochs": 220,
        "train.early_stop_patience": 16
      },
      "checkdir": "checkpoints/torch_vi_only/eta_bias_suite/eta_bias_v1/optimizer_fast_cosine",
      "logfile": "logs/log_vi_only_eta_bias_eta_bias_v1_optimizer_fast_cosine",
      "evaldir": "outputs/vi_only_eta_bias_suite/eta_bias_v1/optimizer_fast_cosine",
      "summary": "outputs/vi_only_eta_bias_suite/eta_bias_v1/optimizer_fast_cosine/posterior_summary.json"
    },
    {
      "id": "combined_candidate",
      "description": "Candidate production recipe: raised center, weaker prior/KL, stronger physics, and higher GP capacity.",
      "config": "configs/vi_only_eta_bias_suite/combined_candidate.cfg",
      "overrides": {
        "prior.eta_init": 15.0,
        "prior.kl_eta": 0.1,
        "prior.num_inducing_x": 32,
        "prior.num_inducing_y": 32,
        "prior.kernel_type": "matern52",
        "prior.anisotropic": true,
        "prior.l_scale_eta_y": 7500.0,
        "train.eta_prior_scale": 0.04,
        "train.eta_prior_std": 2.5,
        "train.phys_scale": 6.0,
        "likelihood.ssa_rx_std": 0.05,
        "likelihood.ssa_ry_std": 0.05,
        "likelihood.ssa_rh_std": 0.05,
        "train.n_epochs": 200,
        "train.early_stop_patience": 12
      },
      "checkdir": "checkpoints/torch_vi_only/eta_bias_suite/eta_bias_v1/combined_candidate",
      "logfile": "logs/log_vi_only_eta_bias_eta_bias_v1_combined_candidate",
      "evaldir": "outputs/vi_only_eta_bias_suite/eta_bias_v1/combined_candidate",
      "summary": "outputs/vi_only_eta_bias_suite/eta_bias_v1/combined_candidate/posterior_summary.json"
    }
  ]
}